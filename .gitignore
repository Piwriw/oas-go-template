# Binaries
/bin/
/dist/
# Bare `go build ./cmd/server` / `go build ./cmd/client` from repo root drops
# `server` / `client` binaries in . — use `make build` to put them under bin/.
/server
/client
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test / build artifacts
*.test
*.out
coverage.txt
coverage.html

# Generated Go code (kept tracked, but in case we add anything transient)
# Note: *.gen.go files ARE tracked; do not ignore them.

# Dependency directories
/vendor/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment files
.env
.env.local
.env.*.local

# Local config (real values, often with secrets; commit only config.example.yaml)
/config.yaml

# Node (web/)
node_modules/
web/dist/
web/.vite/

# Air live-reload tmp
/tmp/
docs/superpowers

# OS
Thumbs.db
